#!/usr/bin/env bash
# Mock codex CLI for the LLM-only test suite.
#
# Mirrors tests/mock-llm/claude but emits the JSONL event stream that
# src/commands/codex_spawn.rs::parse_codex_jsonl consumes. The function
# ignores every JSONL line except `item.completed` whose `item.type` is
# `agent_message`; the last such `item.text` wins.
#
# Two payload shapes are supported, mirroring
# src/extract/llm_embedding.rs (64-dim zero vectors — the active default
# dimensionality since v1.0.79, G42/S1):
# - single: `{"embedding":[...]}` (EmbeddingResponse);
# - batch (G42/S2): `{"items":[{"i":N,"v":[...]}]}` when the prompt asks
#   for an "items" array containing EXACTLY N items.
#
# The prompt arrives on stdin for `codex exec`; `python3 -c` keeps stdin
# free so the heredoc does not shadow it. argv is inspected too for
# symmetry with the claude mock.

set -euo pipefail

ARGS="$*" python3 -c "
import json, os, re, sys

text = os.environ['ARGS']
if not sys.stdin.isatty():
    text += ' ' + sys.stdin.read()
# G51: honour the requested dimensionality instead of hardcoding 64.
# Batch prompts carry it inline; the single path only carries it in the
# --output-schema JSON file (minItems), so read that file when present.
dim = 64
dm = re.search(r'(\d+)-dimensional', text)
if dm:
    dim = int(dm.group(1))
else:
    argv = text.split()
    for flag in ('--output-schema', '--json-schema'):
        if flag in argv:
            try:
                schema = open(argv[argv.index(flag) + 1]).read()
                sm = re.search(r'\"minItems\"\s*:\s*(\d+)', schema)
                if sm:
                    dim = int(sm.group(1))
            except (IndexError, OSError):
                pass
            break
m = re.search(r'EXACTLY (\d+) items', text)
if m:
    n = int(m.group(1))
    payload = {'items': [{'i': i + 1, 'v': [0.0] * dim} for i in range(n)]}
else:
    payload = {'embedding': [0.0] * dim}

events = [
    {'type': 'thread.started', 'thread_id': 'mock-thread-0'},
    {'type': 'turn.started'},
    {
        'type': 'item.completed',
        'item': {'type': 'agent_message', 'text': json.dumps(payload)},
    },
    {
        'type': 'turn.completed',
        'usage': {'input_tokens': 1, 'output_tokens': 1, 'total_tokens': 2},
    },
]
sys.stdout.write('\n'.join(json.dumps(e) for e in events) + '\n')
"

exit 0
