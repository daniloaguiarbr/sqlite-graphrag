{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daniloaguiarbr/sqlite-graphrag/schemas/optimize.schema.json",
  "title": "OptimizeResponse",
  "description": "Response emitted by `sqlite-graphrag optimize` on stdout as a single JSON line.",
  "type": "object",
  "required": ["db_path", "status", "fts_rebuilt", "elapsed_ms"],
  "additionalProperties": false,
  "properties": {
    "db_path":    { "type": "string" },
    "status":     { "type": "string", "enum": ["ok"] },
    "fts_rebuilt": { "type": "boolean", "description": "Whether the FTS5 index was rebuilt during optimization." },
    "elapsed_ms": { "type": "integer", "minimum": 0, "description": "Handler wall-clock time in milliseconds." }
  }
}
