{
  "$id": "https://github.com/daniloaguiarbr/sqlite-graphrag/schemas/backup.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Response emitted by `sqlite-graphrag backup --json` on stdout as a single JSON line.",
  "properties": {
    "action": {
      "const": "backed_up",
      "description": "Always 'backed_up' on success.",
      "type": "string"
    },
    "destination": {
      "description": "Absolute path to the backup file that was written.",
      "type": "string"
    },
    "elapsed_ms": {
      "description": "Handler wall-clock time in milliseconds.",
      "minimum": 0,
      "type": "integer"
    },
    "pages_copied": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "size_bytes": {
      "description": "Size of the backup file in bytes.",
      "minimum": 0,
      "type": "integer"
    },
    "source": {
      "description": "Absolute path to the source SQLite database file.",
      "type": "string"
    },
    "step_size": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    }
  },
  "required": [
    "action",
    "source",
    "destination",
    "size_bytes",
    "elapsed_ms"
  ],
  "title": "BackupResponse",
  "type": "object"
}
