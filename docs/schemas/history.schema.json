{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daniloaguiarbr/sqlite-graphrag/schemas/history.schema.json",
  "title": "HistoryResponse",
  "description": "Response emitted by `sqlite-graphrag history` on stdout as a single JSON line.",
  "$defs": {
    "HistoryVersion": {
      "type": "object",
      "required": ["version", "name", "type", "description", "metadata", "action", "change_reason", "changed_by", "created_at", "created_at_iso"],
      "additionalProperties": false,
      "properties": {
        "version":       { "type": "integer", "minimum": 1 },
        "name":          { "type": "string" },
        "type":          { "type": "string" },
        "description":   { "type": "string" },
        "body":          { "type": "string", "description": "Memory body at this version. Omitted from the response when --no-body is passed." },
        "metadata":      { "type": "string" },
        "action":        { "type": "string", "description": "Past-tense label derived from change_reason (created, edited, renamed, restored, merged, forgotten). Always populated." },
        "change_reason": { "type": ["string", "null"], "description": "Raw verb stored in memory_versions; preserved for backwards compatibility." },
        "changed_by":    { "type": ["string", "null"] },
        "created_at":    { "type": "integer" },
        "created_at_iso":{ "type": "string", "format": "date-time" }
      }
    }
  },
  "type": "object",
  "required": ["name", "namespace", "versions", "elapsed_ms"],
  "additionalProperties": false,
  "properties": {
    "name":       { "type": "string" },
    "namespace":  { "type": "string" },
    "versions":   { "type": "array", "items": { "$ref": "#/$defs/HistoryVersion" } },
    "elapsed_ms": { "type": "integer", "minimum": 0, "description": "Handler wall-clock time in milliseconds." }
  }
}
