{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daniloaguiarbr/sqlite-graphrag/schemas/related.schema.json",
  "title": "RelatedResponse",
  "description": "Response emitted by `sqlite-graphrag related` on stdout as a single JSON line. Exit codes: 0 success, 1 runtime error, 2 CLI usage error, 4 not found.",
  "$defs": {
    "RelatedMemory": {
      "type": "object",
      "required": ["memory_id", "name", "namespace", "type", "description", "hop_distance"],
      "additionalProperties": false,
      "properties": {
        "memory_id":     { "type": "integer" },
        "name":          { "type": "string" },
        "namespace":     { "type": "string" },
        "type":          { "type": "string" },
        "description":   { "type": "string" },
        "hop_distance":  { "type": "integer", "minimum": 1 },
        "source_entity": { "type": ["string", "null"], "description": "Present when traversal found a relationship." },
        "target_entity": { "type": ["string", "null"] },
        "relation":      { "type": ["string", "null"] },
        "weight":        { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 }
      }
    }
  },
  "type": "object",
  "required": ["results", "elapsed_ms"],
  "additionalProperties": false,
  "properties": {
    "results":    { "type": "array", "items": { "$ref": "#/$defs/RelatedMemory" } },
    "elapsed_ms": { "type": "integer", "minimum": 0, "description": "Wall-clock time in milliseconds." }
  }
}
