{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daniloaguiarbr/sqlite-graphrag/schemas/forget.schema.json",
  "title": "ForgetResponse",
  "description": "Response emitted by `sqlite-graphrag forget` on stdout as a single JSON line.",
  "type": "object",
  "required": ["forgotten", "name", "namespace", "elapsed_ms"],
  "additionalProperties": false,
  "properties": {
    "forgotten":  { "type": "boolean", "description": "True when the memory was soft-deleted." },
    "name":       { "type": "string" },
    "namespace":  { "type": "string" },
    "elapsed_ms": { "type": "integer", "minimum": 0, "description": "Handler wall-clock time in milliseconds." }
  }
}
